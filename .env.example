# Copy to .env in the project root (never commit .env).

# Gmail: enable 2FA, then create an App Password (Google Account → Security → App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your.email@gmail.com

# Where reminders are sent (can also set "Owner alert email" in Settings → saves over this)
OWNER_EMAIL=your.email@gmail.com

# Web API session signing (feature/web-api branch — set a long random string in production)
# PT_WEB_SECRET=change-me-to-a-long-random-string

# Extra browser origins for CORS (comma-separated), if not covered by LAN regex
# PT_WEB_ORIGINS=http://192.168.1.42:5173
